{
  "expo": {
    "name": "napsnap",
    "slug": "napsnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "napsnap",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFF8E8",
    "splash": {
      "backgroundColor": "#050505",
      "resizeMode": "contain",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "生活の痕跡を1枚撮るためにカメラを使います。",
        "NSMicrophoneUsageDescription": "その瞬間の音を2.5秒だけ録音します。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050505",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "backgroundColor": "#FFF8E8"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "生活の痕跡を1枚撮るためにカメラを使います。"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "その瞬間の音を2.5秒だけ録音します。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "プロフィール画像を選ぶために写真ライブラリにアクセスします。"
        }
      ]
    ],
    "experiments": {
      "baseUrl": "/napsnap"
    }
  }
}
